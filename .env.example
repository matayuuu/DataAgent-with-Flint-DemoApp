# Foundry Agent Playground - Environment Variables
# Copy this file to .env and fill in your values

# Your Foundry project endpoint
# Format: https://resource_name.ai.azure.com/api/projects/project_name
PROJECT_ENDPOINT=https://your-resource.ai.azure.com/api/projects/your-project

# Default model to use (optional, will be selectable in UI)
DEFAULT_MODEL=gpt-4o-mini

# Server port
PORT=8000
